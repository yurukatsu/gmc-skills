# ──────────────────────────────────────────────────────────
#  gmc-skills-server environment
#  copy to .env and edit before `docker compose up`
# ──────────────────────────────────────────────────────────

# ── Required ───────────────────────────────────────────────

# Bearer token the CLI must send on publish/unpublish.
# Rotate by changing this value and restarting the container.
GMC_SKILLS_TOKEN=change-me-to-a-random-string

# Git remote URL for the registry monorepo. Token can be embedded
# in the URL (https://<user>:<token>@host/path.git) OR supplied via
# GMC_SKILLS_HOST_TOKEN below.
#
#   GitHub:    https://x-access-token:<GH_PAT>@github.com/<org>/<repo>.git
#   GitLab SaaS: https://oauth2:<GL_PAT>@gitlab.com/<group>/<repo>.git
#   GitLab SH:   https://oauth2:<GL_PAT>@gitlab.corp.example.com/<group>/<repo>.git
#   GitLab IP:   http://oauth2:<GL_PAT>@10.0.0.5/<group>/<repo>.git
GMC_SKILLS_GIT_REPO=https://x-access-token:<token>@github.com/<org>/<repo>.git


# ── Optional ───────────────────────────────────────────────

# Default branch on the monorepo (what "latest" tracks).
GMC_SKILLS_GIT_BRANCH=main

# Committer identity used when no X-User-* headers are sent.
GMC_SKILLS_GIT_AUTHOR_NAME=gmc-skills-server
GMC_SKILLS_GIT_AUTHOR_EMAIL=gmc-skills@example.com

# Publish mode: "direct" = commit to default branch immediately.
# "pr" = open a PR/MR via host API for review before merge.
GMC_SKILLS_PUBLISH_MODE=direct

# Force host kind (required for self-hosted GitLab / GitHub Enterprise
# / IP-addressed hosts). Auto-detected for github.com and gitlab.com.
#GMC_SKILLS_GIT_HOST=gitlab

# API token used for PR/MR creation. Falls back to URL-embedded token.
#GMC_SKILLS_HOST_TOKEN=<PAT>

# Override the auto-derived API base (path-prefix GitLab, reverse proxies).
#GMC_SKILLS_HOST_API_BASE=https://corp.example.com/gitlab/api/v4

# Host port mapping — change if 8787 is already taken on the host.
GMC_SKILLS_HOST_PORT=8787
